@import "variables.styl"

.discover-area
  width 100%

.p-tile > .page-link
  display block

.discount
  background home-bg
  color primary-color
  padding 1px 4px
  font-size .75em
  font-weight 600
  border-radius 4px

.p-tile
  margin-bottom 15px
  position relative
  z-index 0
  transition all .1s
  cursor pointer
  border-radius border-radius
  border 1px solid rgba(0, 0, 0, 0)

  &:hover
    .img-wrapper
      & > .compare-btn
        opacity 1
        transform translateX(0)


  .img-wrapper
    margin 5px 0
    position relative


    .badge
    & > .compare-btn
      position absolute
      top 0
      z-index 1


    & > .compare-btn
      right 5px
      opacity 0
      transform translateX(20px)
      transition all .2s

      i
        &.close-icon
          transform scale(.7)

    .badge
      left 5px
      font-size .7em
      padding 2px 5px
      color #fff
      border-radius 3px
      background primary-color

    .fav-btn
      position absolute
      top 10px
      right 10px
      height auto
      font-size 2em
      z-index 10
      line-height 1
      color #666

      span
        line-height 1

.p-tile
  & > .page-link
    display block

.user-compared
.user-wishlists
  .tile-container
    .p-tile
      min-width 25%
      width 25%

.tile-container
  display grid
  grid-template-columns repeat(6, 1fr)
  gap 0
  border-left 1px solid #ddd
  border-top 1px solid #ddd

  .p-tile
    width 100%
    min-width 0
    padding 0
    margin-bottom 0
    border-right 1px solid #ddd
    border-bottom 1px solid #ddd

//RESPONSIVE
@media only screen and (max-width: 1400px)
  .tile-container
    grid-template-columns repeat(5, 1fr)

@media only screen and (max-width: 1200px)
  .tile-container
    grid-template-columns repeat(4, 1fr)

@media only screen and (max-width: 992px)
  .tile-container
    grid-template-columns repeat(3, 1fr)

@media only screen and (max-width: 768px)
  .p-tile .img-wrapper > .compare-btn
    transform none
    opacity 1

  .tile-container
    grid-template-columns repeat(2, 1fr)

@media only screen and (max-width: 576px)
  .tile-container
    grid-template-columns repeat(2, 1fr)
